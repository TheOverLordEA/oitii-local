datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Resume {
  id               String   @id @default(uuid())
  fileName         String
  localPath        String
  parsedText       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model JobApplication {
  id        String   @id @default(uuid())
  company   String
  role      String
  status    String   // e.g., 'PENDING', 'APPLIED', 'INTERVIEWING', 'REJECTED', 'OFFER'
  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
